<Project>
  <PropertyGroup>
    <MewVGTitle>Aprillz.MewVG</MewVGTitle>
    <MewVGVersion>0.3.2</MewVGVersion>
    <MewVGAuthor>Aprillz</MewVGAuthor>
    <MewVGDescription>A cross-platform, fully managed .NET vector graphics library based on NanoVG.</MewVGDescription>

    <MewVGRootNamespace>Aprillz.MewVG</MewVGRootNamespace>
    <MewVGTargetFrameworks>net8.0;net10.0</MewVGTargetFrameworks>
    <MewVGPackageLicenseExpression>MIT</MewVGPackageLicenseExpression>

    <TargetFrameworks>$(MewVGTargetFrameworks)</TargetFrameworks>
    <Version>$(MewVGVersion)</Version>
    <RootNamespace>$(MewVGRootNamespace)</RootNamespace>
    <PackageLicenseExpression>$(MewVGPackageLicenseExpression)</PackageLicenseExpression>
    <PackageIcon>logo_c-256.png</PackageIcon>

    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <PublishRepositoryUrl>false</PublishRepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <IncludeSource>true</IncludeSource>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)..\assets\logo\logo_c-256.png" Pack="true" PackagePath="" />
  </ItemGroup>
</Project>
